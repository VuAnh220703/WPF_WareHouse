<UserControl x:Class="WPF_demo_01.Views.Frame_Admin.Add_Supplier_dialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_demo_01.Views.Frame_Admin"  xmlns:viewmodels="clr-namespace:WPF_demo_01.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:AdViewmodel_NhaCungCap}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#0056C6"/>
                                <Setter TargetName="InputBorder" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#F9FAFB" 
            Padding="25" 
            CornerRadius="16" 
            Width="800" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center"
            Margin="20">

        <Border.Effect>
            <DropShadowEffect BlurRadius="25" 
                              Color="Black" 
                              Opacity="0.25" 
                              ShadowDepth="5" 
                              Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Thêm nhà cung cấp mới" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Nhập thông tin chi tiết để đăng ký đối tác cung ứng mới vào hệ thống." FontSize="13" Foreground="#6B7280" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.7*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" BorderBrush="#E4E7EB" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="ⓘ" Foreground="#0056C6" FontWeight="Bold" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Thông tin cơ bản" FontSize="15" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Margin="0,0,0,15"/>

                        <TextBlock Margin="0,0,0,6">
                            <Run Text="Tên nhà cung cấp" Foreground="#374151" FontWeight="Medium"/>
                            <Run Text=" *" Foreground="#EF4444"/>
                        </TextBlock>
                        <Grid Margin="0,0,0,15">
                            <TextBox x:Name="TxtName" Padding="10,0" />
                            <TextBlock Text="VD: Công ty CP Thực phẩm Sạch..." Foreground="#9CA3AF" VerticalAlignment="Center" Margin="14,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtName}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Margin="0,0,0,6">
                                    <Run Text="Số điện thoại" Foreground="#374151" FontWeight="Medium"/>
                                    <Run Text=" *" Foreground="#EF4444"/>
                                </TextBlock>
                                <Grid>
                                    <TextBox x:Name="TxtPhone" Padding="10,0"/>
                                    <TextBlock Text="090 123 4567" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="14,0" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=TxtPhone}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Email liên hệ" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,6"/>
                                <Grid>
                                    <TextBox x:Name="TxtEmail" Padding="10,0"/>
                                    <TextBlock Text="contact@supplier.com" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="14,0" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=TxtEmail}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Địa chỉ trụ sở" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,6"/>
                        <Grid>
                            <TextBox x:Name="TxtAddress" Padding="10,0"/>
                            <TextBlock Text="Số nhà, Tên đường, Quận/Huyện, Tỉnh/Thành phố" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="14,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtAddress}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" BorderBrush="#E4E7EB" BorderThickness="1" CornerRadius="12" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="📋" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Chi tiết hợp tác" FontSize="15" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Loại hợp đồng" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,6"/>
                        <ComboBox Text="Chọn hình thức..."/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="White" BorderBrush="#E4E7EB" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="📁" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Tài liệu đính kèm" FontSize="15" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Height="130" Margin="0,5,0,0"
      AllowDrop="True"
      Background="Transparent"
      Cursor="Hand"
      DragOver="UploadZone_DragOver"
      Drop="UploadZone_Drop"
      PreviewMouseLeftButtonDown="UploadZone_MouseClick">

                        <Rectangle Stroke="#D1D5DB" StrokeDashArray="4 3" StrokeThickness="1.5" RadiusX="8" RadiusY="8"/>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                            <Border Width="42" Height="42" Background="#EBF3FF" CornerRadius="21" HorizontalAlignment="Center" Margin="0,0,0,12">
                                <TextBlock Text="📄" FontSize="20" Foreground="#0056C6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="TxtFileName" HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#137333" Visibility="Collapsed" Margin="0,0,0,5"/>

                            <TextBlock x:Name="TxtUploadPrompt" HorizontalAlignment="Center" FontSize="14">
            <Run Text="Kéo thả tệp hợp đồng hoặc " Foreground="#374151"/>
            <Run Text="duyệt trên máy" Foreground="#0056C6" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock Text="Hỗ trợ định dạng PDF, DOCX (Tối đa 10MB)" Foreground="#6B7280" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Command="{Binding HideAddOverlayVisible}" Content="Hủy" Height="40" Padding="24,0" FontSize="14" FontWeight="Medium" Foreground="#4B5563" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,12,0"/>

                <Button Content="Lưu thông tin" Height="40" Padding="20,0" FontSize="14" FontWeight="SemiBold" Background="#0056C6" Foreground="White" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="💾" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0046A2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>