<UserControl x:Class="WPF_demo_01.Views.Frame_Admin.Detail_DanhMuc_Kho_constrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_demo_01.Views.Frame_Admin"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Padding="50">
    <Border Background="White" 
        CornerRadius="10" 
        BorderBrush="#1E90FF" 
        BorderThickness="1" 
        HorizontalAlignment="Stretch" 
        VerticalAlignment="Stretch">
        <Grid >
            <!--button exit-->
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="9*"/>
            </Grid.RowDefinitions>
            <Button Grid.Row="0" 
            Content="✕" 
            Command="{Binding DataContext.HideDetailOverlayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            HorizontalAlignment="Right" 
            VerticalAlignment="Top"
            Width="32" 
            Height="32"
            FontSize="18"
            FontWeight="Bold"
            Cursor="Hand">

                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#666666"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="4" 
                                    Background="{TemplateBinding Background}" 
                                    BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFEAEA"/>
                                <Setter Property="Foreground" Value="Red"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FCD3D3"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <!-- content-->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5*" />
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                
                <!-- hiển thị thông tin danh mục và các nhà cung cấp danh mục đó-->
                <StackPanel Grid.Column="0" Margin="10,0" DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <TextBlock Text="CHI TIẾT DANH MỤC" FontSize="20" FontWeight="Bold"/>
                    <StackPanel Margin="10" DataContext="{Binding CurrentSelectedCategory}" Orientation="Vertical">
                        <TextBlock Text="Tên danh mục:"/>
                        <Border CornerRadius="5" BorderThickness="1" BorderBrush="gray" Padding="5" Margin="0,5,0,15">
                            <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>
                        
                        <TextBlock Text="Mô tả chi tiết:"/>
                        <Border CornerRadius="5" BorderThickness="1" BorderBrush="gray" Padding="5" >
                            <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True"
         TextWrapping="Wrap"
         VerticalScrollBarVisibility="Auto"
         Height="100" 
         VerticalContentAlignment="Top"/>
                        </Border>
                    </StackPanel>
<!-- nhà cung cấp cho danh mục-->
                    <StackPanel>
                        <TextBlock Text="Danh sách nhà cung cấp" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Danh sách trống (Chức năng chưa viết)"/>
                    </StackPanel>
                </StackPanel>
                
                <!--hiển thị các kho đang có danh mục đó-->
                <Grid Grid.Column="1">
                    
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
