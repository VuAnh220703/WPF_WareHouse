<UserControl x:Class="WPF_demo_01.Views.Frame_Admin.NhaCungCap"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_demo_01.Views.Frame_Admin"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E4E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#0056C6"/>
                    <Setter Property="Background" Value="#FAFAFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F9FAFB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="10">
            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBlock Text="Quản lý nhà cung cấp" 
                           FontSize="26" 
                           FontWeight="Bold" 
                           Foreground="#111827"/>
                <TextBlock Text="Giám sát và quản lý danh sách nhà cung cấp thực phẩm." 
                           FontSize="13" 
                           Foreground="#6B7280" 
                           Margin="0,6,0,0"/>
            </StackPanel>

            <Button DockPanel.Dock="Right" 
                    Content="+ Thêm nhà cung cấp" 
                    Height="40" 
                    Padding="16,0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    Command="{Binding ShowAddOverlayVisible}"
                    >
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#0056C6"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0046A2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#00357A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <UniformGrid Columns="3">

                <Border Style="{StaticResource DashboardCardStyle}">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Tổng số nhà cung cấp" Foreground="#666666" FontSize="13" Margin="0,0,0,6"/>
                            <TextBlock Text="142" Foreground="#111111" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" Width="46" Height="46" Background="#EBF3FF" CornerRadius="23" VerticalAlignment="Center">
                            <TextBlock Text="🏢" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Hợp đồng đang hiệu lực" Foreground="#666666" FontSize="13" Margin="0,0,0,6"/>
                            <TextBlock Text="128" Foreground="#111111" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" Width="46" Height="46" Background="#EDF5FF" CornerRadius="23" VerticalAlignment="Center">
                            <TextBlock Text="📋" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource DashboardCardStyle}">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Nhà cung cấp mới (30 ngày)" Foreground="#666666" FontSize="13" Margin="0,0,0,6"/>
                            <TextBlock Text="12" Foreground="#111111" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" Width="46" Height="46" Background="#E6F4EA" CornerRadius="23" VerticalAlignment="Center">
                            <TextBlock Text="✅" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

            </UniformGrid>
        </Grid>

        <Border Grid.Row="2" 
        Background="White" 
        CornerRadius="12" 
        BorderBrush="#E4E7EB" 
        BorderThickness="1"
        Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20,15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="Danh sách nhà cung cấp" FontSize="16" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                        <Border Background="#F3F4F6" CornerRadius="10" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="142" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ComboBox Width="180" Height="36" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,8,0"
                          Text="Lọc theo Danh mục..." IsEditable="True" IsReadOnly="True">
                        </ComboBox>
                        <Button Width="36" Height="36" Background="White" BorderBrush="#E4E7EB" BorderThickness="1" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6">
                                                    <TextBlock Text="≡" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#4B5563"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="0" BorderBrush="#E4E7EB" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding FilteredSuppliers}" 
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E5E7EB"
                  Background="Transparent"
                  BorderThickness="0"
                  RowHeight="60">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="Foreground" Value="#4B5563"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="15,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#4B5563"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="TÊN NHÀ CUNG CẤP" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="10,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="36" Height="36" Background="#E5E7EB" CornerRadius="6" Margin="0,0,12,0">
                                            <TextBlock Text="DG" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#4B5563" FontSize="12"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#111827" FontSize="14"/>
                                            <TextBlock Text="{Binding Address}" Foreground="#6B7280" FontSize="12" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="DANH MỤC" Binding="{Binding CategoryName}" Width="1.5*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#111827"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="TRẠNG THÁI" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="StatusPill" Background="#E6F4EA" CornerRadius="12" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#137333" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="StatusText" Text="Dang hiệu lực" Foreground="#137333" FontSize="12" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                            <Setter TargetName="StatusPill" Property="Background" Value="#FEF3C7"/>
                                            <Setter TargetName="StatusDot" Property="Fill" Value="#D97706"/>
                                            <Setter TargetName="StatusText" Property="Text" Value="Chờ duyệt"/>
                                            <Setter TargetName="StatusText" Property="Foreground" Value="#D97706"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Expired">
                                            <Setter TargetName="StatusPill" Property="Background" Value="#F3F4F6"/>
                                            <Setter TargetName="StatusDot" Property="Fill" Value="#6B7280"/>
                                            <Setter TargetName="StatusText" Property="Text" Value="Hết hạn"/>
                                            <Setter TargetName="StatusText" Property="Foreground" Value="#6B7280"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="HÀNH ĐỘNG" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Button Content="✏️" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,5,0"/>
                                        <Button Content="🗑️" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2" BorderBrush="#E4E7EB" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>

                <Grid Grid.Row="2" Margin="20,12">
                    <TextBlock Text="Hiển thị 1-5 trong 142 nhà cung cấp" Foreground="#4B5563" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&lt;" Width="32" Height="32" Margin="2" Background="White" BorderBrush="#E4E7EB"/>

                        <Button Content="1" Width="32" Height="32" Margin="2" Background="#0056C6" Foreground="White" FontWeight="Bold"/>

                        <Button Content="2" Width="32" Height="32" Margin="2" Background="White" BorderBrush="#E4E7EB"/>
                        <Button Content="3" Width="32" Height="32" Margin="2" Background="White" BorderBrush="#E4E7EB"/>
                        <TextBlock Text="..." VerticalAlignment="Center" Margin="5,0" Foreground="#9CA3AF"/>
                        <Button Content="29" Width="32" Height="32" Margin="2" Background="White" BorderBrush="#E4E7EB"/>

                        <Button Content="&gt;" Width="32" Height="32" Margin="2" Background="White" BorderBrush="#E4E7EB"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="0" 
      Grid.RowSpan="3"
      Visibility="{Binding IsAddOverlayVisible, Converter={StaticResource BoolToVis}}"
      Background="#60000000">

            <local:Add_Supplier_dialog DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}" />

        </Grid>
    </Grid>
</UserControl>
