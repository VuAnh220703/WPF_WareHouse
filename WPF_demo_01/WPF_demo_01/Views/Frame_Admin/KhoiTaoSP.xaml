<UserControl x:Class="WPF_demo_01.Views.Frame_Admin.KhoiTaoSP"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_demo_01.Views.Frame_Admin"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- [SECTION] HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <TextBlock FontWeight="Bold" Foreground="#004277" FontSize="25" Text="Thêm sản phẩm mới" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Height="35" Background="White" Margin="5,0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" Margin="10,0">
                        <Image Source="/Icons/icon_excel.png" Width="18" Height="18" Margin="0,0,5,0"/>
                        <TextBlock Text="Nhập từ EXCEL" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                </Button>

                <Button Height="35" Background="#004277" Foreground="White" Margin="5,0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" Margin="10,0">
                        <Image Source="/Icons/icon_save.png" Width="18" Height="18" Margin="0,0,5,0"/>
                        <TextBlock Text="Lưu sản phẩm" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- [SECTION] MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" />
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- CỘT TRÁI (Thông tin & Hình ảnh) -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Thông tin sản phẩm" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Style="{StaticResource TitleStyle}" Text="TÊN SẢN PHẨM"/>
                    <Border Background="#F0F4F8" Margin="0,5,0,15" CornerRadius="5" Padding="5">
                        <TextBox FontSize="13" Height="30" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"/>
                    </Border>

                    <TextBlock Style="{StaticResource TitleStyle}" Text="MÔ TẢ SẢN PHẨM"/>
                    <Border Background="#F0F4F8" Margin="0,5,0,15" CornerRadius="5" Padding="5">
                        <TextBox Height="90" TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0" Background="Transparent"/>
                    </Border>

                    <TextBlock Style="{StaticResource TitleStyle}" Text="THÀNH PHẦN SẢN PHẨM"/>
                    <Border Background="#F0F4F8" Margin="0,5,0,20" CornerRadius="5" Padding="5">
                        <TextBox Height="60" TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0" Background="Transparent"/>
                    </Border>

                    <!-- PHẦN HÌNH ẢNH TRONG SCROLL -->
                    <Grid Margin="0,10,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="180"/>
                            <!-- Chiều cao cố định cho khu vực chứa ảnh -->
                        </Grid.RowDefinitions>

                        <!-- Tiêu đề hình ảnh -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Style="{StaticResource TitleStyle}">
                                <Run Text="Hình ảnh sản phẩm"/>
                                <Run Text="{Binding TotalImages, StringFormat='({0} ảnh)', Mode=OneWay}" Foreground="Gray" FontSize="14"/>
                            </TextBlock>
                            <Button Content="+ Thêm hình" HorizontalAlignment="Right" Padding="12,4" Cursor="Hand"
                                    Background="White" Command="{Binding AddImageCommand}"/>
                        </Grid>

                        <!-- List ảnh -->
                        <Grid Grid.Row="1">
                            <Border Background="#F0F4F8" CornerRadius="8">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding SelectedImages}" Margin="5">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="5">
                                                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Background="White">
                                                        <Image Source="{Binding}" Width="140" Height="100" Stretch="UniformToFill" />
                                                    </Border>
                                                    <Button Content="✕" FontWeight="Bold" Height="24" Background="#FF4B4B" Foreground="White"
                                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="-5,-5,0,0"
                                                            Command="{Binding DataContext.RemoveImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="11"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <!-- Thông báo khi chưa có ảnh -->
                            <TextBlock Text="Chưa có hình ảnh nào được thêm" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                                       Foreground="#999" IsHitTestVisible="False" FontStyle="Italic">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TotalImages}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- CỘT PHẢI (Barcode, Giá, Số lượng) -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Style="{StaticResource TitleStyle}" Text="BARCODE"/>
                <Grid Margin="0,5,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#F0F4F8" CornerRadius="5" Padding="5">
                        <TextBox Text="{Binding BarcodeValue, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"/>
                    </Border>
                    <Button Height="40" Grid.Column="1" Command="{Binding SelectBarcodeImageCommand}" Background="Transparent" BorderThickness="0">
                        <Image Width="30" Height="30" Source="/Icons/icon_qrcode.png" Cursor="Hand"/>
                    </Button>
                </Grid>

                <UniformGrid Columns="1">
                    <!-- Chuyển thành 1 cột để text không bị cắt khi thu nhỏ -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Style="{StaticResource TitleStyle}" Text="GIÁ NIÊM YẾT"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="16" Foreground="#004277" FontWeight="Bold" Text="0,000 VND" Margin="0,5,5,0"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Style="{StaticResource TitleStyle}" Text="SỐ LƯỢNG TỒN"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="16" Foreground="#004277" FontWeight="Bold" Text="0 (đơn vị)" Margin="0,5,5,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Height="30">
                        <Image Source="/Icons/icon_phanloai.png" Width="20" Height="20"  />
                        <TextBlock Padding="10,0" FontWeight="Bold" VerticalAlignment="Center" FontSize="16" Text="PHÂN LOẠI &amp; CUNG ỨNG"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,10,15" Width="150">
                            <TextBlock Style="{StaticResource TitleStyle}" Text="PHÂN LOẠI"/>

                            <Border Background="#F0F4F8" Margin="0,5" CornerRadius="5" Padding="5,0">
                                <ComboBox Height="30" 
          BorderThickness="0" 
          Background="Transparent" 
          VerticalContentAlignment="Center"
          SelectedIndex="0">
                                    <ComboBox.Resources>
                                        <!-- 1. Màu nền khi di chuột qua (Hover) -->
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D1E8FF" />
                                        <!-- 2. Màu chữ khi di chuột qua -->
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black" />
                                        <!-- 3. Màu nền khi danh sách đang đóng (Tránh nhìn xuyên) -->
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White" />
                                    </ComboBox.Resources>

                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <!-- Đảm bảo mỗi Item luôn có nền trắng mặc định -->
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Padding" Value="8,5"/>
                                            <Style.Triggers>
                                                <!-- Xử lý khi chuột rê qua để không bị trong suốt -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#D1E8FF"/>
                                                    <Setter Property="Foreground" Value="Black"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>

                                    <ComboBoxItem Content="Thực phẩm &amp; Đồ uống"/>
                                    <ComboBoxItem Content="Hàng gia dụng"/>
                                    <ComboBoxItem Content="Điện tử &amp; Công nghệ"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15" Width="150">
                            <TextBlock Style="{StaticResource TitleStyle}" Text="NHÀ CUNG ỨNG"/>
                            <Border Background="#F0F4F8" Margin="0,5" CornerRadius="5" Padding="5,0">
                                <ComboBox Height="30" 
          BorderThickness="0" 
          Background="Transparent" 
          VerticalContentAlignment="Center"
          SelectedIndex="0">
                                    <ComboBox.Resources>
                                        <!-- 1. Màu nền khi di chuột qua (Hover) -->
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D1E8FF" />
                                        <!-- 2. Màu chữ khi di chuột qua -->
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black" />
                                        <!-- 3. Màu nền khi danh sách đang đóng (Tránh nhìn xuyên) -->
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White" />
                                    </ComboBox.Resources>

                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <!-- Đảm bảo mỗi Item luôn có nền trắng mặc định -->
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Padding" Value="8,5"/>
                                            <Style.Triggers>
                                                <!-- Xử lý khi chuột rê qua để không bị trong suốt -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#D1E8FF"/>
                                                    <Setter Property="Foreground" Value="Black"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>

                                    <ComboBoxItem Content="Thực phẩm &amp; Đồ uống"/>
                                    <ComboBoxItem Content="Hàng gia dụng"/>
                                    <ComboBoxItem Content="Điện tử &amp; Công nghệ"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                </UniformGrid>
                
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>